    {
      "parameters": {
        "jsCode": "// ============================================================\n// DESCARGA + PAGINACIÓN + PARSEO ATOM — v11 (filtro PUB + limpieza texto)\n// - next SOLO se busca en la cabecera del feed (antes de la\n//   primera <entry>), en cualquier orden de atributos.\n// - Tope duro de páginas para que NUNCA se cuelgue.\n// - Si no hay next, procesa la primera página y termina.\n// ============================================================\n\nconst urlBase = 'https://contrataciondelsectorpublico.gob.es/sindicacion/sindicacion_643/licitacionesPerfilesContratanteCompleto3.atom';\nconst desde = new Date(Date.now() - 3 * 24 * 60 * 60 * 1000).toISOString().split('T')[0];\nconst hasta = new Date().toISOString().split('T')[0];\nconst MAX_PAGINAS = 10;   // red de seguridad: nunca más de 10 páginas\n\n// Solo licitaciones con el plazo abierto. PUB = en plazo de presentación.\n// Añade 'PRE' si quieres ver también los anuncios previos.\nconst ESTADOS_VALIDOS = ['PUB'];\n\nfunction decode(s){\n  if (s == null) return '';\n  return String(s)\n    .replace(/<!\\[CDATA\\[([\\s\\S]*?)\\]\\]>/g, '$1')\n    .replace(/&lt;/g,'<').replace(/&gt;/g,'>')\n    .replace(/&quot;/g,'\"').replace(/&#39;/g,\"'\").replace(/&apos;/g,\"'\")\n    .replace(/&amp;/g,'&')\n    .trim();\n}\n\nfunction stripTags(s){ return String(s||'').replace(/<[^>]*>/g,'').trim(); }\n// Neutraliza comillas y saltos que rompen el JSON del body de Ollama\nfunction limpiarTexto(s){ return String(s||'').replace(/&#x?[0-9a-fA-F]+;/g,' ').replace(/[\\r\\n]+/g,' ').replace(/\"/g,\"'\").replace(/\\s+/g,' ').trim(); }\nfunction firstTag(xml, suffix){\n  const re = new RegExp('<([\\\\w-]+:)?' + suffix + '\\\\b[^>]*>([\\\\s\\\\S]*?)<\\\\/([\\\\w-]+:)?' + suffix + '>', 'i');\n  const m = xml.match(re);\n  return m ? decode(m[2]) : '';\n}\n\n// Busca rel=\"next\" en cualquier orden de atributos, SOLO en el texto dado\nfunction findNext(headerXml){\n  const links = headerXml.match(/<link\\b[^>]*>/gi) || [];\n  for (const tag of links){\n    if (/rel=[\"']next[\"']/i.test(tag)){\n      const h = tag.match(/href=[\"']([^\"']+)[\"']/i);\n      if (h) return decode(h[1]);\n    }\n  }\n  return '';\n}\n\nfunction splitEntries(xml){\n  const out = [];\n  const re = /<entry\\b[^>]*>([\\s\\S]*?)<\\/entry>/gi;\n  let m;\n  while ((m = re.exec(xml)) !== null){ out.push(m[1]); }\n  return out;\n}\n\nfunction parseEntry(entryXml){\n  const titulo = firstTag(entryXml, 'title') || 'Sin título';\n  const descripcion = firstTag(entryXml, 'summary') || '';\n  const fechaPublicacion = firstTag(entryXml, 'updated') || firstTag(entryXml, 'published') || '';\n  let link = '';\n  const linkTags = entryXml.match(/<link\\b[^>]*>/gi) || [];\n  const alt = linkTags.find(t => /rel=[\"']alternate[\"']/i.test(t)) || linkTags[0];\n  if (alt){ const h = alt.match(/href=[\"']([^\"']+)[\"']/i); if (h) link = decode(h[1]); }\n\n  const organismo  = stripTags(firstTag(entryXml, 'PartyName') || firstTag(entryXml, 'Name') || '');\n  const presupuesto = stripTags(firstTag(entryXml, 'TaxExclusiveAmount') || firstTag(entryXml, 'TotalAmount') || firstTag(entryXml, 'Amount') || 'No especificado');\n  const cpv = firstTag(entryXml, 'ItemClassificationCode') || firstTag(entryXml, 'ClassificationCode') || '';\n  const estado = firstTag(entryXml, 'ContractFolderStatusCode') || firstTag(entryXml, 'StatusCode') || '';\n  const fechaLimite = firstTag(entryXml, 'EndDate') || firstTag(entryXml, 'DeadlineDate') || 'Ver pliego';\n\n  // Extraer idEvl del link como identificador único de la licitación\n  let idEvl = '';\n  const mId = String(link).match(/idEvl=([^&]+)/i);\n  if (mId) idEvl = decodeURIComponent(mId[1]);\n  const tituloLimpio = limpiarTexto(titulo);\n  const descripcionLimpia = limpiarTexto(descripcion);\n  const textoCompleto = `${tituloLimpio} ${descripcionLimpia}`.toLowerCase();\n  return { idEvl, titulo: tituloLimpio, descripcion: descripcionLimpia, link, organismo: limpiarTexto(organismo), presupuesto, cpv, estado, fechaLimite, textoCompleto, fechaPublicacion };\n}\n\nconst salida = [];\nlet nextUrl = urlBase;\nlet pagina = 0;\n\nwhile (nextUrl && pagina < MAX_PAGINAS){\n  pagina++;\n\n  let xml;\n  try {\n    xml = await this.helpers.httpRequest({\n      method: 'GET',\n      url: nextUrl,\n      headers: { 'User-Agent': 'Mozilla/5.0 (compatible; n8n-licitaciones/1.0)' },\n      timeout: 120000,\n      json: false\n    });\n  } catch (e){ break; }\n  if (typeof xml !== 'string') xml = String(xml);\n\n  // separar cabecera (antes de la primera <entry>) del resto\n  const idx = xml.search(/<entry\\b/i);\n  const cabecera = idx > -1 ? xml.slice(0, idx) : xml;\n\n  const entries = splitEntries(xml);\n  let fechasPagina = [];\n  for (const eXml of entries){\n    const p = parseEntry(eXml);\n    const fechaPub = String(p.fechaPublicacion).slice(0,10);\n    if (fechaPub) fechasPagina.push(fechaPub);\n    if (fechaPub && fechaPub >= desde && fechaPub <= hasta && ESTADOS_VALIDOS.includes(p.estado)){\n      salida.push({ json: p });\n    }\n  }\n\n  const candidato = findNext(cabecera);\n  const minFecha = fechasPagina.length ? fechasPagina.sort()[0] : '';\n\n  if (!candidato || (minFecha && minFecha < desde)){\n    nextUrl = null;\n  } else {\n    nextUrl = candidato;\n  }\n}\n\nif (salida.length === 0){\n  return [{ json: { _vacio: true, mensaje: 'Sin licitaciones en la ventana', desde, hasta, paginasLeidas: pagina } }];\n}\nreturn salida;"
      },
