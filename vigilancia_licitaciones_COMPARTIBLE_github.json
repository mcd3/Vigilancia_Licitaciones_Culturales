        "jsCode": "const keywords = [\n  { kw: \"museo\", peso: 10 },\n  { kw: \"realidad aumentada\", peso: 10 },\n  { kw: \"realidad virtual\", peso: 10 },\n  { kw: \"experiencia inmersiva\", peso: 10 },\n  { kw: \"inmersiv\", peso: 8 },\n  { kw: \"digitaliz\", peso: 9 },\n  { kw: \"contenidos digital\", peso: 9 },\n  { kw: \"patrimonio\", peso: 8 },\n  { kw: \"exposici\", peso: 8 },\n  { kw: \"fotogrametría\", peso: 9 },\n  { kw: \"escaneado 3d\", peso: 9 },\n  { kw: \"modelado 3d\", peso: 9 },\n  { kw: \"gemelo digital\", peso: 9 },\n  { kw: \"visita virtual\", peso: 9 },\n  { kw: \"metaverso\", peso: 8 },\n  { kw: \"teatro\", peso: 7 },\n  { kw: \"ópera\", peso: 7 },\n  { kw: \"audiovisual\", peso: 7 },\n  { kw: \"producción audiovisual\", peso: 8 },\n  { kw: \"transcodif\", peso: 7 },\n  { kw: \"multimedia\", peso: 6 },\n  { kw: \"streaming\", peso: 6 },\n  { kw: \"fotografía\", peso: 7 },\n  { kw: \"catalogación\", peso: 6 },\n  { kw: \"colección\", peso: 6 },\n  { kw: \"archivo\", peso: 5 },\n  { kw: \"biblioteca\", peso: 5 },\n  { kw: \"turismo digital\", peso: 8 },\n  { kw: \"turismo\", peso: 4 },\n  { kw: \"cultural\", peso: 5 },\n  { kw: \"arte\", peso: 4 },\n  { kw: \"escénic\", peso: 6 },\n  { kw: \"festival\", peso: 5 },\n  { kw: \"señalética\", peso: 5 },\n  { kw: \"interactiv\", peso: 7 },\n  { kw: \"documental\", peso: 6 },\n  { kw: \"sitio web\", peso: 4 },\n  { kw: \"página web\", peso: 4 },\n  { kw: \"portal web\", peso: 4 },\n  { kw: \"aplicación móvil\", peso: 6 },\n  { kw: \"app móvil\", peso: 6 },\n  { kw: \"contenidos\", peso: 1 },\n  { kw: \"plataforma\", peso: 1 }\n];\n\n// Umbral mínimo: por debajo de este score se descarta (no llega a la IA)\nconst UMBRAL_MINIMO = 7;\n\nconst salida = [];\nfor (const entrada of $input.all()) {\n  const item = entrada.json;\n  const texto = item.textoCompleto || \"\";\n\n  const encontradas = keywords.filter(k => texto.includes(k.kw));\n  const score = encontradas.reduce((acc, k) => acc + k.peso, 0);\n  const etiquetas = encontradas.map(k => k.kw).join(\", \");\n\n  if (score < UMBRAL_MINIMO) continue;\n\n  let relevancia = \"⚪ BAJA\";\n  if (score >= 8)  relevancia = \"🟡 MEDIA\";\n  if (score >= 15) relevancia = \"🟢 ALTA\";\n  if (score >= 25) relevancia = \"🔴 MUY ALTA\";\n\n  salida.push({ json: { ...item, score, etiquetas, relevancia } });\n}\n\nreturn salida;",
        "mode": "runOnceForAllItems"
      },
