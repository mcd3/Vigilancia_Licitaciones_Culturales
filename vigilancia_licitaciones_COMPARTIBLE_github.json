      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Deduplicación por idEvl, robusta frente a:\n//  - codificado (%3D) vs decodificado (==)\n//  - apóstrofo inicial que Sheets añade al texto\n//  - celdas #ERROR! (cuando un id antiguo empezaba por + sin escapar)\nfunction normId(v){\n  let s = String(v == null ? \"\" : v).trim();\n  if (!s || s === \"#ERROR!\") return \"\";\n  if (s.charAt(0) === \"'\") s = s.slice(1);        // quita apóstrofo inicial\n  try { if (/%[0-9a-fA-F]{2}/.test(s)) s = decodeURIComponent(s); } catch(e){}\n  return s.trim();\n}\n\nconst yaGuardados = new Set();\nfor (const row of $input.all()) {\n  const raw = row.json.idEvl ?? row.json.IdEvl ?? row.json.idevl ?? row.json.ID;\n  const id = normId(raw);\n  if (id) yaGuardados.add(id);\n}\n\nlet nuevas = [];\ntry { nuevas = $(\"📊 Score de relevancia\").all(); } catch (e) { nuevas = []; }\n\nconst salida = [];\nconst vistos = new Set();\nfor (const entrada of nuevas) {\n  const it = entrada.json;\n  const id = normId(it.idEvl);\n  if (id && (yaGuardados.has(id) || vistos.has(id))) continue;\n  if (id) vistos.add(id);\n  salida.push({ json: it });\n}\nreturn salida;"
      },
