        "jsCode": "// Modo \"Run Once for All Items\": itera todas las licitaciones analizadas\nconst salida = [];\nfor (const entrada of $input.all()) {\n  const d = entrada.json;\n  const msg = `${d.emoji} *LICITACIÓN ${d.accion}*\n\n*${d.titulo}*\n🏛 ${d.organismo}\n${d.relevancia} | Score: ${d.score}\n🏷 ${d.etiquetas}\n\n📋 *OBJETO:*\n${d.objeto || 'Ver pliego'}\n\n💶 *PRESUPUESTO:* ${d.presupuesto || 'No especificado'}\n📅 *LÍMITE:* ${d.fecha_limite || d.fechaLimite || 'Ver pliego'}\n\n🎯 *CRITERIOS:*\n${d.criterios || 'Ver pliego'}\n\n✅ *ENCAJE:* ${d.encaje}\n${d.justificacion || ''}\n\n⚠️ *RIESGOS:*\n${d.riesgos || 'Ninguno detectado'}\n\n🔗 [Ver licitación](${d.link})`;\n\n  salida.push({ json: { mensaje: msg, ...d } });\n}\nreturn salida;",
        "mode": "runOnceForAllItems"
      },
