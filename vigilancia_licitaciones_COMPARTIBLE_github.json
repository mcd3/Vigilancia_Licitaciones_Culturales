    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:11434/api/generate",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"gemma3:27b\",\n  \"prompt\": \"Eres un experto en contratación pública española especializado en digitalización cultural.\\n\\nAnaliza esta licitación y responde ÚNICAMENTE con un objeto JSON válido, sin texto adicional, sin markdown, sin explicaciones:\\n\\n{\\n  \\\"objeto\\\": \\\"descripción en 2 líneas máximo\\\",\\n  \\\"presupuesto\\\": \\\"importe si aparece, o No especificado\\\",\\n  \\\"plazo\\\": \\\"plazo de ejecución\\\",\\n  \\\"fecha_limite\\\": \\\"fecha límite presentación\\\",\\n  \\\"criterios\\\": \\\"criterios de adjudicación con porcentajes si aparecen\\\",\\n  \\\"encaje\\\": \\\"APTO, DUDOSO o NO_APTO\\\",\\n  \\\"justificacion\\\": \\\"por qué encaja con empresa de digitalización cultural, AR, fotografía, contenidos digitales y turismo\\\",\\n  \\\"riesgos\\\": \\\"puntos críticos a revisar\\\",\\n  \\\"accion\\\": \\\"PRESENTARSE, ESTUDIAR o DESCARTAR\\\"\\n}\\n\\nLICITACIÓN:\\nTítulo: {{ $json.titulo }}\\nOrganismo: {{ $json.organismo }}\\nDescripción: {{ $json.descripcion }}\\nCPV: {{ $json.cpv }}\\nPresupuesto: {{ $json.presupuesto }}\\nFecha límite: {{ $json.fechaLimite }}\\nRelevancia: {{ $json.relevancia }} | Keywords: {{ $json.etiquetas }}\",\n  \"stream\": false,\n  \"options\": { \"temperature\": 0.2 }\n}",
        "options": {
          "timeout": 180000
        }
      },
      "id": "1f93503f-2e60-4c09-8cae-2fa02ce85235",
      "name": "🤖 IA local · configurar endpoint",
