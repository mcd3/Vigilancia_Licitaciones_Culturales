    {
      "parameters": {
        "jsCode": "// Modo \"Run Once for All Items\". Itera todas las respuestas de la IA.\n// Recupera los datos originales via pairedItem (robusto aunque Score haya filtrado).\nconst salida = [];\nconst items = $input.all();\n\nfor (let i = 0; i < items.length; i++) {\n  const item = items[i].json;\n  const raw = item.response || \"{}\";\n\n  // Datos originales de la licitacion: emparejados por indice con el nodo Score.\n  // Usamos itemMatching(i) que respeta pairedItem; si falla, caemos al propio item.\n  let orig = {};\n  try {\n    orig = $(\"📊 Score de relevancia\").all()[i].json;\n  } catch (e) {\n    orig = item;\n  }\n\n  let analisis = {};\n  try {\n    const clean = String(raw).replace(/```json/g, \"\").replace(/```/g, \"\").trim();\n    analisis = JSON.parse(clean);\n  } catch (e) {\n    analisis = { objeto: \"Error de parsing\", encaje: \"DUDOSO\", accion: \"ESTUDIAR\", justificacion: String(raw).substring(0, 300), riesgos: \"Revisar manualmente\" };\n  }\n\n  const emojiAccion = { \"PRESENTARSE\": \"✅\", \"ESTUDIAR\": \"🔎\", \"DESCARTAR\": \"❌\" };\n  const emoji = emojiAccion[analisis.accion] || \"🔎\";\n\n  salida.push({\n    json: {\n      idEvl: orig.idEvl || \"\",\n      titulo: orig.titulo || \"Sin título\",\n      organismo: orig.organismo || \"\",\n      link: orig.link || \"\",\n      presupuesto: orig.presupuesto || \"\",\n      fechaLimite: orig.fechaLimite || \"\",\n      fechaPublicacion: orig.fechaPublicacion || \"\",\n      relevancia: orig.relevancia || \"\",\n      etiquetas: orig.etiquetas || \"\",\n      score: orig.score ?? \"\",\n      ...analisis,\n      emoji,\n      procesadoEn: new Date().toISOString()\n    }\n  });\n}\n\nreturn salida;",
        "mode": "runOnceForAllItems"
      },
