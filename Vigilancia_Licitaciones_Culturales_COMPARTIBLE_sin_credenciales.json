    {
      "parameters": {
        "jsCode": "const item = $input.item.json;\nconst raw = item.response || \"{}\";\n\n// Recuperar los datos originales de la licitación del nodo Score\nlet orig = {};\ntry {\n  orig = $('📊 Score de relevancia').item.json;\n} catch(e) {\n  orig = item;\n}\n\nlet analisis = {};\ntry {\n  const clean = String(raw).replace(/```json/g, \"\").replace(/```/g, \"\").trim();\n  analisis = JSON.parse(clean);\n} catch(e) {\n  analisis = { objeto: \"Error de parsing\", encaje: \"DUDOSO\", accion: \"ESTUDIAR\", justificacion: String(raw).substring(0, 300), riesgos: \"Revisar manualmente\" };\n}\n\nconst emojiAccion = { \"PRESENTARSE\": \"✅\", \"ESTUDIAR\": \"🔎\", \"DESCARTAR\": \"❌\" };\nconst emoji = emojiAccion[analisis.accion] || \"🔎\";\n\nreturn {\n  json: {\n    titulo: orig.titulo || \"Sin título\",\n    organismo: orig.organismo || \"\",\n    link: orig.link || \"\",\n    fechaPublicacion: orig.fechaPublicacion || \"\",\n    relevancia: orig.relevancia || \"\",\n    etiquetas: orig.etiquetas || \"\",\n    score: orig.score ?? \"\",\n    ...analisis,\n    emoji,\n    procesadoEn: new Date().toISOString()\n  }\n};"
      },
